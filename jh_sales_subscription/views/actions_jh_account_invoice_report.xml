<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="account_invoice_report_list_inherit" model="ir.ui.view">
            <field name="name">account.invoice.report.list.inherit</field>
            <field name="model">account.invoice.report</field>
            <field name="inherit_id" ref="account_invoice_line_report.view_invoice_report_tree_info"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='move_id']" position="before">
                    <field name="jh_invoice_date"/>
                </xpath>
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="jh_agents"/>
                    <field name="jh_commission" widget="monetary"/>
                    <field name="jh_commission_percent" widget="float" options="{'precision': 2}"/>
                    <field name="jh_commission_settlement_date"/>
                    <field name="jh_serial_number"/>
                    <field name="jh_country_id"/>
                    <field name="jh_state_id"/>
                </xpath>
                <xpath expr="//field[@name='jh_state_id']" position="after">
                    <field name="jh_payment_mode_id"/>
                    <field name="jh_payment_term_id"/>
                </xpath>
                <xpath expr="//field[@name='price_average']" position="after">
                    <field name="price_margin"/>
                    <field name="jh_cost"/>
                    <field name="jh_margin_percent"/>
                    <field name="jh_tax_id"/>
<!--                    <field name="jh_tax_amount"/>-->
                    <field name="jh_new_tax"/>
                </xpath>
                <xpath expr="//field[@name='company_currency_id']" position="replace"/>
            </field>
        </record>

<!--        filtros al search       -->
        <record id="custom_account_invoice_report_search_inherit" model="ir.ui.view">
          <field name="name">account.invoice.report.search.inherit.jh</field>
          <field name="model">account.invoice.report</field>
          <field name="inherit_id" ref="account_invoice_line_report.view_account_invoice_report_search"/>
          <field name="arch" type="xml">
            <xpath expr="//field[@name='product_categ_id']" position="after">
              <separator/>
              <filter string="País" name="group_by_jh_country" context="{'group_by':'jh_country_id'}"/>
              <filter string="Provincia" name="group_by_jh_state" context="{'group_by':'jh_state_id'}"/>
              <filter string="Impuesto" name="group_by_jh_tax_id" context="{'group_by':'jh_tax_id'}"/>
            </xpath>
          </field>
        </record>

        <record id="view_move_line_tree_inherit_iva_done" model="ir.ui.view">
          <field name="name">account.move.line.tree.iva.done</field>
          <field name="model">account.move.line</field>
          <field name="inherit_id" ref="account.view_move_line_tree"/>
          <field name="arch" type="xml">
            <xpath expr="//tree/field[last()]" position="after">
              <field name="jh_tax_recalc_done" readonly="1" invisible="1"/>
            </xpath>
          </field>
        </record>


    </data>
</odoo>
