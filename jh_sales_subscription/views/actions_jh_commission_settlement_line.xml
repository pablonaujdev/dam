<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="commission_view_settlement_form_inherit_jh_fields" model="ir.ui.view">
            <field name="name">commission.view.settlement.form.inherit.jh.fields</field>
            <field name="model">commission.settlement</field>
            <field name="inherit_id" ref="commission.view_settlement_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='settled_amount']" position="before">
                    <field name="jh_serial_number"/>
                    <field name="jh_total_amount"/>
                    <field name="jh_commission_percent"/>
                </xpath>

                <xpath expr="//field[@name='invoice_line_id']" position="attributes">
                    <attribute name="string">Origen de línea de Factura</attribute>
                </xpath>

                <xpath expr="//field[@name='invoice_line_id']" position="before">
                    <field name="jh_invoice_id" widget="many2one"/>
                    <field name="jh_product_id" widget="many2one" 
                           context="{'commission_context': True}"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
