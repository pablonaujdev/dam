<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_form_inherit_shipping_invoice" model="ir.ui.view">
            <field name="name">sale.order.form.inherit.shipping.invoice</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="mode">extension</field>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                    <attribute name="domain">
                        [
                            '|',
                                ('id', '=', partner_id),
                                '&amp;',
                                    ('commercial_partner_id', '=', commercial_partner_id),
                                    ('type', '=', 'invoice')
                        ]
                    </attribute>
                </xpath>

                <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                    <attribute name="domain">
                        [
                            '|',
                                ('id', '=', partner_id),
                                '&amp;',
                                    ('commercial_partner_id', '=', commercial_partner_id),
                                    ('type', '=', 'delivery')
                        ]
                    </attribute>
                </xpath>

            </field>

        </record>

        <record id="view_order_tree_inherit_material_delivery_status" model="ir.ui.view">
            <field name="name">sale.order.tree.material.delivery.status</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_status']" position="after">
                    <field name="jh_delivery_status"
                           string="Entrega material"
                           widget="badge"
                           optional="show"
                           decoration-muted="jh_delivery_status in ('draft','not_required')"
                           decoration-danger="jh_delivery_status in ('pending','delivery_cancelled')"
                           decoration-warning="jh_delivery_status in ('started','partial')"
                           decoration-success="jh_delivery_status == 'full'"/>
                </xpath>

            </field>
        </record>

       <record id="view_quotation_tree_inherit_material_delivery_status" model="ir.ui.view">
           <field name="name">sale.quotation.tree.material.delivery.status</field>
           <field name="model">sale.order</field>
           <field name="inherit_id" ref="sale.view_quotation_tree"/>
           <field name="arch" type="xml">
               <xpath expr="//field[@name='invoice_status']" position="after">
                   <field name="jh_delivery_status"
                          string="Entrega material"
                          widget="badge"
                          optional="show"
                          decoration-muted="jh_delivery_status in ('draft','not_required')"
                          decoration-danger="jh_delivery_status in ('pending','delivery_cancelled')"
                          decoration-warning="jh_delivery_status in ('started','partial')"
                          decoration-success="jh_delivery_status == 'full'"/>
               </xpath>
           </field>
       </record>

    </data>
</odoo>
