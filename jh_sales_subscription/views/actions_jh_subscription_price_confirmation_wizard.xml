<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_jh_subscription_price_confirmation_wizard_form" model="ir.ui.view">
            <field name="name">jh.subscription.price.confirmation.wizard.form</field>
            <field name="model">jh.subscription.price.confirmation.wizard</field>
            <field name="arch" type="xml">
                <form string="Confirmar actualización de precios">
                    <group>
                        <field name="title" readonly="1" nolabel="1"/>
                        <field name="message" readonly="1" nolabel="1"/>
                    </group>
                    <footer>
                        <button name="action_keep_current_conditions" string="Mantener condiciones actuales" type="object" class="btn-secondary"/>
                        <button name="action_update_tariff" string="Actualizar según tarifa vigente" type="object" class="btn-primary"/>
                        <button string="Cancelar" special="cancel" class="btn-link"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
